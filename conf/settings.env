#!/usr/bin/env bash

#Target services to check
#Add any standard systemd services here

SYSTEM_SERVICES=("sshd" "apparmor" "systemd-networkd")

#k3s specific settings 
#k3s (server) or k3s-agent (worker)
K3S_SERVICE_NAME="k3s"
KUBECONFIG_PATH='/etc/rancher/k3s/k3s.yaml"

# System Threshold
DISK-WARNING_THRESHOLD=85

